# ===================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ===================================================================
VITE_API_URL=http://localhost:3000
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug
VITE_SENTRY_DSN=

# ===================================================================
# BACKEND ENVIRONMENT VARIABLES
# ===================================================================

# Database
DATABASE_URL=postgresql://sitegenie:password@localhost:5432/sitegenie
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Providers
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Storage
S3_BUCKET=sitegenie-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_aws_access_key
S3_SECRET_ACCESS_KEY=your_aws_secret_key

# Cloud Deployment
VERCEL_API_TOKEN=your_vercel_token
VERCEL_TOKEN=
NETLIFY_API_TOKEN=your_netlify_token
NETLIFY_AUTH_TOKEN=
RAILWAY_API_TOKEN=your_railway_token
RENDER_API_TOKEN=your_render_token
E2B_API_KEY=

# Monitoring & Observability
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=
VITE_SENTRY_DSN=
DATADOG_API_KEY=
LOG_LEVEL=info
ENABLE_METRICS=true

# Server
PORT=3000
PORT=3001
NODE_ENV=development
LOG_FORMAT=json
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
ENABLE_EXPERIMENTAL=false
ENABLE_BETA_AGENTS=false
ENABLE_COLLABORATION=true
ENABLE_ADVANCED_ANALYTICS=false

# Sandbox & Execution
SANDBOX_MEMORY_MB=512
SANDBOX_TIMEOUT_MS=30000
SANDBOX_MAX_CONCURRENT=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
GENERATION_RATE_LIMIT=10

# Cache
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# ===================================================================
# DOCKER & KUBERNETES
# ===================================================================
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
KUBE_NAMESPACE=sitegenie
KUBE_CLUSTER_NAME=sitegenie-prod

# ===================================================================
# DEVELOPMENT ONLY
# ===================================================================
DEBUG=sitegenie:*
VITE_DEBUG_MODE=true
MOCK_AI_RESPONSES=false
VITE_API_URL=
