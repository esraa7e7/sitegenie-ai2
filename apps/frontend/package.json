{
  "name": "sitegenie-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-ready AI platform for building websites with Multi-Agent Architecture",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:server": "tsx watch src/server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd apps/frontend && npm run build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "cd apps/frontend && npm run preview",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf node_modules dist build .turbo apps/*/node_modules packages/*/node_modules",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.460.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "@codesandbox/sandpack-react": "^2.19.10",
    "@google/generative-ai": "^0.21.0",
    "@monaco-editor/react": "^4.6.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.40.0",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.3",
    "date-fns": "^4.1.0",
    "e2b": "^1.0.1",
    "fflate": "^0.8.2",
    "framer-motion": "^11.13.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.73.0",
    "pako": "^2.1.0",
    "posthog-node": "^4.4.1",
    "recharts": "^2.13.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  }
}