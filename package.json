{
  "name": "sitegenie-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "api/server.js",
  "packageManager": "pnpm@9.5.0",
  "workspaces": [
    "apps/frontend",
    "packages/*",
    "api",
    "infrastructure"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "turbo run typecheck",
    "audit": "npm audit --audit-level=moderate",
    "test": "turbo run test",
    "build:vercel": "npm run build --workspace=apps/frontend && npm run build --workspace=@sitegenie/ai-server && prisma generate --data-proxy && prisma db push --preview-feature",
    "clean": "turbo run clean",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.15",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "e2b": "^1.0.1",
    "express": "^4.21.1",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.11",
    "openai": "^4.73.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^14.0.0",
    "xss-clean": "^0.1.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "turbo": "^2.9.14",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x"
  }
}
