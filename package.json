{
  "name": "sitegenie-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-ready AI platform for building websites with Multi-Agent Architecture",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch src/server.ts",
    "build": "tsc && vite build",
    "build:frontend": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "start:server": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf node_modules dist build .turbo",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0",
    "@anthropic-ai/sdk": "^0.95.1",
    "@codesandbox/sandpack-react": "^2.19.10",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^9.2.0",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.6",
    "date-fns": "^4.1.0",
    "e2b": "^2.19.5",
    "fflate": "^0.8.2",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.37.0",
    "pako": "^2.1.0",
    "posthog-node": "^4.4.1",
    "recharts": "^2.15.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}