{
  "name": "sitegenie-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:server": "tsx watch src/server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd apps/frontend && npm run build",
    "build:server": "tsc -p tsconfig.server.json --skipLibCheck",
    "preview": "cd apps/frontend && npm run preview",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf node_modules dist build .turbo apps/*/node_modules packages/*/node_modules",
    "lint": "eslint . --ext ts,tsx --quiet || true",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "type-check": "tsc --noEmit --skipLibCheck",
    "postinstall": "prisma generate --skip-generate || echo 'Postinstall completed'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.40.0",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.3",
    "date-fns": "^4.1.0",
    "e2b": "^1.0.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.73.0",
    "posthog-node": "^4.4.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "uuid": "^11.0.3"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  }
}