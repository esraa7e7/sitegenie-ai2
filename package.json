{
  "name": "sitegenie-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:server": "tsx watch src/server.ts",
    "build": "npm run build:all",
    "build:all": "npm run build:frontend && npm run build:server",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:server": "tsc -p tsconfig.server.json --skipLibCheck",
    "preview": "cd apps/frontend && npm run preview",
    "start": "node dist/server.js",
    "clean": "rm -rf node_modules dist build .turbo apps/*/node_modules packages/*/node_modules",
    "postinstall": "echo 'Postinstall completed - SiteGenie AI'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "e2b": "^1.0.1",
    "express": "^4.21.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.73.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  }
}
