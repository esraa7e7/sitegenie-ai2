{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "./",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@sitegenie/shared": ["../shared/src"],
      "@sitegenie/shared-types": ["../shared-types/src"]
    }
  },
  "include": ["./**/*.ts"],
  "references": [
    { "path": "../shared" },
    { "path": "../shared-types" }
  ]
}