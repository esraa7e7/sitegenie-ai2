{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "files": [],
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client", "node"],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/shared-types" },
    { "path": "packages/common" },
    { "path": "packages/ai-core" },
    { "path": "packages/auth" },
    { "path": "packages/logger" },
    { "path": "packages/ai-server" },
    { "path": "packages/prompts" },
    { "path": "packages/monitoring" },
    { "path": "packages/storage" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist",
    "apps/frontend/dist",
    "apps/frontend/index-*.js",
    "apps/frontend/vendor-*.js",
    "apps/frontend/*.config.js",
    "apps/frontend/*.css",
    "apps/frontend_old",
    "apps/frontend_old/dist",
    "packages/**/dist"
  ]
}
