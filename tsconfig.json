{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/frontend/src/*"],
      "@sitegenie/ai-core": ["packages/ai-core/src/index.ts"],
      "@sitegenie/ai-core/*": ["packages/ai-core/src/*"],
      "@sitegenie/shared": ["packages/shared/src/index.ts"],
      "@sitegenie/shared/*": ["packages/shared/src/*"],
      "@sitegenie/ui": ["packages/ui/src/index.ts"],
      "@sitegenie/ui/*": ["packages/ui/src/*"],
      "@sitegenie/config": ["packages/config/src/index.ts"],
      "@sitegenie/config/*": ["packages/config/src/*"]
    },
    "types": ["vite/client", "node"],
    // "allowImportingTsExtensions": true, // Removed as it requires noEmit or emitDeclarationOnly
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "apps/frontend/src/**/*",
    "apps/frontend/src/**/*.ts",
    "apps/frontend/src/**/*.tsx",
    "apps/frontend/src/**/*.d.ts",
    "packages/*/src/**/*",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}

