{
  "version": 2,
  "builds": [
    {
      "src": "packages/ai-server/dist/server.js",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs24.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/ai-server/dist/server.js"
    }
  ],
  "functions": {
    "packages/ai-server/dist/server.js": {
      "runtime": "nodejs24.x"
    }
  }
}