{
  "version": 2,
  "builds": [
    {
      "src": "packages/ai-server/dist/server.js",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs24.x",
        "includeFiles": ["packages/ai-server/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/ai-server/dist/server.js"
    }
  ]
}